# API backend URL'i (FastAPI/Flask vb.)
NEXT_PUBLIC_API_URL=http://localhost:8010

# Public site URL'i — canonical, sitemap, OG image base
# Lokal: http://localhost:3010 | Production: https://hukukemsal.tr
NEXT_PUBLIC_SITE_URL=http://localhost:3010

# --- NextAuth (ZORUNLU) ---
# Lokal: http://localhost:3010 | Production: https://hukukemsal.tr
NEXTAUTH_URL=http://localhost:3010
# Backend .env'deki NEXTAUTH_SECRET ile AYNI olmalı (JWT iki tarafta da çözülür)
NEXTAUTH_SECRET=change-me-min-32-chars-random

# --- Postgres (ZORUNLU — NextAuth kullanıcı sorguları) ---
DATABASE_URL=postgresql://hukuk:localdev_change_me@localhost:5432/hukuk_emsal

# Opsiyonel — analitik / takip
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=hukukemsal.tr
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Opsiyonel — sentry vb.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Server-side (NEXT_PUBLIC önekisiz)
# API_INTERNAL_TOKEN=
