# =============================================================================
# secrets.env.example — SECRET değerleri şablonu
#
# KULLANIM:
#   cp secrets.env.example secrets.env
#   secrets.env içindeki "__DOLDUR__" alanlarını gerçek değerlerle doldur.
#   (secrets.env git'e GİTMEZ — .gitignore'a eklendi.)
#
# NOT:
#   - DATABASE_URL / SERVICE_DATABASE_URL / ADMIN_DATABASE_URL burada YOK;
#     onları script, deploy.env'deki DB kullanıcı/parolalarından otomatik üretir.
#   - NEXTAUTH_SECRET / MASTER_ENCRYPTION_KEY boş bırakılırsa script otomatik
#     üretir (openssl rand). İstersen kendi değerini yaz.
# =============================================================================

# ---- LLM sağlayıcılar -------------------------------------------------------
ANTHROPIC_API_KEY="__DOLDUR__"        # sk-ant-...
GOOGLE_API_KEY="__DOLDUR__"           # AIza...

# ---- Oturum / şifreleme (boşsa script üretir) -------------------------------
NEXTAUTH_SECRET=""                    # boş bırak → openssl rand -base64 32
MASTER_ENCRYPTION_KEY=""              # boş bırak → openssl rand -base64 32

# ---- iyzico (canlı) ---------------------------------------------------------
IYZICO_API_KEY="__DOLDUR__"
IYZICO_SECRET_KEY="__DOLDUR__"
IYZICO_WEBHOOK_SECRET="__DOLDUR__"
IYZICO_PLAN_PRO_SOLO="__DOLDUR__"     # pricing-plan referans kodu
IYZICO_PLAN_PRO_UYAP="__DOLDUR__"
IYZICO_PLAN_TEAM="__DOLDUR__"
IYZICO_PLAN_TEAM_UYAP="__DOLDUR__"

# ---- SMTP (e-posta) ---------------------------------------------------------
SMTP_HOST="__DOLDUR__"                # ör. smtp.resend.com
SMTP_PORT="587"
SMTP_USER="__DOLDUR__"
SMTP_PASS="__DOLDUR__"
SMTP_FROM="no-reply@hukukcuyapayzekasi.com"

# ---- Admin bildirim e-postası ----------------------------------------------
ADMIN_EMAIL="admin@hukukcuyapayzekasi.com"
