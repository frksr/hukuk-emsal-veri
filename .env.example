# LLM provider API key'leri — bunlardan en az birini doldur

# Anthropic (Claude) — en kaliteli Türkçe hukuk metin üretimi
ANTHROPIC_API_KEY=sk-ant-...

# Google AI Studio (Gemini) — daha ekonomik alternatif
GOOGLE_API_KEY=AIza...

# Default provider seçimi: anthropic | gemini
LLM_DEFAULT_PROVIDER=anthropic

# Model seçimleri (boş bırakırsan default değerler kullanılır)
ANTHROPIC_MODEL=claude-sonnet-4-5
GEMINI_MODEL=gemini-2.0-flash-exp

# Embedding model (lokal — API key gerekmez)
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# ============================================================================
# BACKEND API (FastAPI)
# ============================================================================

# --- Veritabanı ---
# Kullanıcı istekleri için RLS'e TABİ rol (app_user). Local Docker'da test için
# aşağıdaki RLS rol kurulumunu (infra/db/08_local_roles.sql) uygulayın.
DATABASE_URL=postgresql://app_user:app_user_pw@localhost:5432/hukuk_emsal
# Cross-tenant/sistem işleri için RLS BYPASS rol (app_service).
# Set edilmezse DATABASE_URL'e düşer ve RLS ikinci katmanı pasif kalır.
SERVICE_DATABASE_URL=postgresql://app_service:app_service_pw@localhost:5432/hukuk_emsal

# --- Auth ---
NEXTAUTH_SECRET=change-me-min-32-chars-random

# --- Şifreleme (envelope encryption master key) ---
# Üret: openssl rand -base64 32  — KAYBOLURSA tüm tenant verisi okunamaz!
# Production'da KMS'ten gelmeli.
MASTER_ENCRYPTION_KEY=

# --- PII / KVKK (isim-adres maskeleme) ---
# Türkçe NER modeli; boş bırakılırsa heuristik (kural tabanlı) katman kullanılır.
PII_NER_MODEL=savasy/bert-base-turkish-ner-cased
# NER de heuristik de isim maskeleyemezse yurt dışı LLM çağrısını engelle (1=engelle)
PII_BLOCK_FOREIGN_LLM_WITHOUT_NER=0

# --- iyzico (ödeme) ---
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_WEBHOOK_SECRET=
IYZICO_PLAN_PRO_SOLO=
IYZICO_PLAN_PRO_UYAP=
IYZICO_PLAN_TEAM=
IYZICO_PLAN_TEAM_UYAP=

# --- E-posta (SMTP) ---
# Local: docker-compose mailpit → host:1026, web UI http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_USER=dev
SMTP_PASS=dev
SMTP_FROM=noreply@hukukemsal.tr
SMTP_FROM_NAME=Hukuk Emsal

# --- Observability ---
SENTRY_DSN=
APP_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Vektör DB + büyük veri (git'te DEĞİL; kalıcı volume'a seed edilir) ---
# Cloud'da kalıcı volume'u /data'ya mount edin ve aşağıdakileri oraya yönlendirin.
# Lokal geliştirmede bu satırları boş bırakın → varsayılan data/... kullanılır.
# CHROMA_DIR=/data/chroma_db                 # public emsal vektör DB (~2GB)
# DECISIONS_PARQUET=/data/final/all_decisions.parquet  # tam karar metni kaynağı
# CHROMA_COLLECTION=hukuk_kararlari
# TENANT_CHROMA_DIR=/data/tenant_chroma      # per-tenant vektör (runtime, OKU-YAZ)
# TENANT_STORAGE_ROOT=/data/tenant_storage   # per-tenant şifreli dosyalar

# --- Diğer ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501
TENANT_STORAGE_ROOT=data/tenant_storage
